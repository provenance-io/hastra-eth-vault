{
  "name": "hastra-eth-vault",
  "version": "1.0.0",
  "description": "Ethereum implementation of Hastra Vault Protocol with ERC-4626 compliance",
  "main": "index.js",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:coverage": "hardhat coverage",
    "test:fuzz": "forge test",
    "test:fuzz:verbose": "forge test -vvv",
    "test:fuzz:gas": "forge test --gas-report",
    "test:fuzz:deep": "FOUNDRY_PROFILE=deep forge test",
    "test:all": "yarn test && yarn test:fuzz",
    "lint": "tsc --noEmit --skipLibCheck",
    "deploy:local": "hardhat run scripts/deploy/deploy.ts --network localhost",
    "deploy:hoodi": "hardhat run scripts/deploy/deploy.ts --network hoodi",
    "deploy:sepolia": "hardhat run scripts/deploy/deploy.ts --network sepolia",
    "deploy:mainnet": "hardhat run scripts/deploy/deploy.ts --network mainnet",
    "node": "hardhat node",
    "verify": "hardhat verify",
    "clean": "hardhat clean && forge clean",
    "typechain": "hardhat typechain"
  },
  "packageManager": "yarn@1.22.19",
  "keywords": [
    "ethereum",
    "vault",
    "erc4626",
    "defi",
    "staking",
    "yield"
  ],
  "author": "Hastra",
  "license": "Apache-2.0",
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.0.0",
    "@nomicfoundation/hardhat-ethers": "^3.0.0",
    "@nomicfoundation/hardhat-network-helpers": "^1.0.0",
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@nomicfoundation/hardhat-verify": "^2.0.0",
    "@openzeppelin/hardhat-upgrades": "^3.9.1",
    "@typechain/ethers-v6": "^0.5.0",
    "@typechain/hardhat": "^9.0.0",
    "@types/chai": "^4.3.0",
    "@types/minimatch": "^5.1.2",
    "@types/mocha": "^10.0.0",
    "@types/node": "^20.19.30",
    "chai": "^4.3.0",
    "ethers": "^6.10.0",
    "hardhat": "^2.19.0",
    "hardhat-gas-reporter": "^1.0.0",
    "merkletreejs": "^0.6.0",
    "solidity-coverage": "^0.8.0",
    "ts-node": "^10.9.2",
    "typechain": "^8.3.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.0.1",
    "@openzeppelin/contracts-upgradeable": "^5.4.0",
    "dotenv": "^16.3.0"
  },
  "resolutions": {
    "fast-xml-parser": "5.3.6",
    "lodash": "4.17.23",
    "undici": "6.23.0",
    "elliptic": "6.6.1"
  },
  "overrides": {
    "fast-xml-parser": "5.3.6"
  }
}
