# NAV Updater Bot Configuration

# Private key for updater account (with or without 0x prefix)
PRIVATE_KEY=your_private_key_here

# HastraNavEngine contract address (deployed on Hoodi)
NAV_ENGINE_ADDRESS=0xF48621B9d8F5D9D0729bb54d67A9d21757fe95cd

# RPC endpoint for Hoodi network
RPC_URL=https://ethereum-hoodi-rpc.publicnode.com

# Chain ID for Hoodi
CHAIN_ID=560048

# Update interval in seconds (default: 3600 = 1 hour)
UPDATE_INTERVAL=3600

# Gas settings (optional)
GAS_LIMIT=500000
MAX_GAS_PRICE_GWEI=50
